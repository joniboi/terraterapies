{
  "name": "simple-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "// --- Original Scripts (Hoarded) ---": "",
    "dev": "next dev",
    "build": "echo \"DEBUG: Resend Key exists: ${RESEND_API_KEY:+yes}\" && drizzle-kit push && next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "drizzle-kit push",
    "db:patch": "npx tsx scripts/fix-bonos.ts",
    "db:seed": "npx tsx scripts/seed-settings.ts",
    "db:dump": "npx tsx scripts/dump-local-settings.ts",
    "// --- Multi-Brand Development ---": "",
    "dev:terra": "dotenv -e .env.terra -- next dev --port 3000",
    "dev:lotus": "dotenv -e .env.lotus -- next dev --port 3001",
    "// --- Multi-Brand Database Management ---": "",
    "db:push:terra": "dotenv -e .env.terra -- drizzle-kit push",
    "db:push:lotus": "dotenv -e .env.lotus -- drizzle-kit push",
    "db:studio:terra": "dotenv -e .env.terra -- drizzle-kit studio",
    "db:studio:lotus": "dotenv -e .env.lotus -- drizzle-kit studio"
  },
  "dependencies": {
